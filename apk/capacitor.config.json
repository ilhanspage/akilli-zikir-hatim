{
  "appId": "com.ilhanbeluk.akillizikirhatim",
  "appName": "Akıllı Zikir & Hatim",
  "webDir": "../app",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#031915",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#031915"
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#d7af68",
      "sound": "default"
    }
  }
}